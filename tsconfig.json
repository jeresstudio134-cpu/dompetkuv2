{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    "jsx": "react-jsx",

    "strict": false,
    "skipLibCheck": true,

    "allowJs": true,
    "resolveJsonModule": true,
    "isolatedModules": true,

    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,

    "types": [
      "node",
      "react",
      "react-dom",
      "vite/client"
    ],

    "baseUrl": ".",

    "paths": {
      "@/*": ["./*"]
    }
  },

  "include": [
    "src",
    "api",
    "server.ts",
    "vite.config.ts"
  ]
}